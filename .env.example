# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=code_analyzer
POSTGRES_PASSWORD=change_me
POSTGRES_DB=code_analysis

# Redis
REDIS_URL=redis://redis:6379/0

# LLM (DeepSeek / OpenAI compatible)
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# API Keys
API_KEYS={"mvp_key": "default_project"}

# Temp
TEMP_DIR=/tmp/code_analysis

# GitHub (for cloning private repositories)
# Generate at: https://github.com/settings/tokens (need repo scope)
# Alternatively, use SSH key mount (see docker-compose.yml)
GITHUB_TOKEN=
